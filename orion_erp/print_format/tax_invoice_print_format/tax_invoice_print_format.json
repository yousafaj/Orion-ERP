{
 "absolute_value": 0,
 "align_labels_right": 0,
 "creation": "2026-04-21 13:36:39.989520",
 "custom_format": 1,
 "default_print_language": "en-US",
 "disabled": 0,
 "doc_type": "Sales Invoice",
 "docstatus": 0,
 "doctype": "Print Format",
 "font": "",
 "font_size": 14,
 "html": "<style>\r\n@page {\r\n    margin-top: 30px;\r\n}\r\n\r\n\r\n.print-format {\r\n    padding-top: 30px !important;\r\n}\r\n    .letter-head-footer {\r\n        margin: 0 !important;\r\n        padding: 0 !important;\r\n    }\r\n    @media screen {\r\n        .print-format {\r\n            width: 9.4in;\r\n            padding: 0.20in;\r\n            min-height: 11.7in;\r\n        }\r\n    }\r\n    .print-format p{\r\n        \r\n    margin:1px 0;\r\n    line-height:1.1;\r\n}\r\n\r\n.print-format td{\r\n    line-height:1.1;\r\n}\r\nbody {\r\n    margin:0 !important;\r\n    padding:0 !important;\r\n}\r\n\r\n.header-table{\r\n    width:100%;\r\n}\r\n\r\n.logo{\r\n    font-size:12px;\r\n    font-weight:bold;\r\n    color:#2f6b3c;\r\n}\r\n\r\n\r\n\r\n.items-table{\r\n    width:100%;\r\n    border-collapse:collapse;\r\n   margin:0;\r\n}\r\n\r\n.items-table th{\r\n    background:#cce7d5;\r\n    border:1px solid #ccc;\r\n    padding:8px;\r\n}\r\n\r\n.items-table td{\r\n    border:1px solid #ccc;\r\n    padding:8px;\r\n    font-size:10px;\r\n}\r\n.items-table td .ql-editor{\r\n    overflow: visible !important;\r\n    max-height: none !important;\r\n    height: auto !important;\r\n}\r\n\r\n.items-table td div{\r\n    overflow: visible !important;\r\n    max-height: none !important;\r\n}\r\n\r\n.items-table td{\r\n    vertical-align: top;\r\n}\r\n.total-box{\r\n    background:#2db45d;\r\n    color:white;\r\n    font-weight:bold;\r\n    padding:10px;\r\n    text-align:right;\r\n    font-size:12px;\r\n}\r\n\r\n</style>\r\n\r\n\r\n\r\n<!-- HEADER SECTION -->\r\n\r\n<div id=\"header-html\" style=\"height:25px;\">\r\n    <div class=\"header-img\"></div>\r\n</div>\r\n\r\n<table class=\"header-table\">\r\n\r\n<tr>\r\n\r\n<td style=\"width:25%;\">\r\n{% set logo = frappe.db.get_value(\"Orion Settings\", None, \"company_logo\") %}\r\n\r\n{% if logo %}\r\n    <img src=\"{{ frappe.utils.get_url(logo) }}\"\r\n         style=\"height:45px;\">\r\n{% endif %}\r\n</td>\r\n\r\n<td class=\"invoice-title\" style=\"font-size:28px;font-weight:bold;text-align:right;font-weight:300;\">\r\nTax Invoice\r\n</td>\r\n\r\n</tr>\r\n\r\n</table>\r\n\r\n\r\n<table style=\"width:100%; border-collapse:collapse; border-spacing:0; font-size:10px;\">\r\n\r\n<tr>\r\n\r\n<!-- Billed By -->\r\n<td width=\"30\" style=\"vertical-align:top; padding-right:8px;\">\r\n\r\n<p style=\"margin:0 0 6px 0;\">Billed By</p>\r\n\r\n<p style=\"margin:0 0 6px 0; font-weight:bold; text-transform:uppercase;\">\r\n{{ doc.company }}\r\n</p>\r\n\r\n{% set comp_addr = frappe.db.sql(\"\"\"\r\n    SELECT a.address_line1, a.address_line2, a.city, a.state, a.country, a.pincode,\r\n           a.phone, a.fax, a.email_id\r\n    FROM `tabAddress` a\r\n    INNER JOIN `tabDynamic Link` l ON l.parent = a.name\r\n    WHERE l.link_doctype = 'Company'\r\n    AND l.link_name = %s\r\n    AND a.is_primary_address = 1\r\n    LIMIT 1\r\n\"\"\", (doc.company,), as_dict=1) %}\r\n\r\n{% if comp_addr %}\r\n<p style=\"margin:0 0 4px 0; font-size:9px;\">\r\n    {{ comp_addr[0].address_line1 or \"\" }}<br>\r\n    {% if comp_addr[0].address_line2 %}{{ comp_addr[0].address_line2 }}<br>{% endif %}\r\n    {{ comp_addr[0].city or \"\" }}<br>\r\n    {{ comp_addr[0].country or \"\" }}{% if comp_addr[0].pincode %} - {{ comp_addr[0].pincode }}{% endif %}<br><br>\r\n\r\n    {% if comp_addr[0].phone %}Phone: {{ comp_addr[0].phone }}<br>{% endif %}\r\n    {% if comp_addr[0].email_id %}Email: {{ comp_addr[0].email_id }}{% endif %}\r\n</p>\r\n{% endif %}\r\n\r\n<p style=\"margin:0; font-weight:bold;\">\r\nTRN : {{ doc.company_tax_id }}\r\n</p>\r\n\r\n</td>\r\n\r\n\r\n<!-- Billed To -->\r\n<td width=\"34%\" style=\"vertical-align:top; padding-right:8px;\">\r\n\r\n<p style=\"margin:0 0 6px 0;\">Billed To</p>\r\n\r\n<p style=\"margin:0 0 6px 0; font-weight:bold;\">\r\n{{ doc.customer_name }}\r\n</p>\r\n\r\n{% if doc.customer_address %}\r\n{% set cust_addr = frappe.db.get_value(\r\n    \"Address\",\r\n    doc.customer_address,\r\n    [\"address_line1\",\"address_line2\",\"city\",\"country\",\"pincode\"],\r\n    as_dict=1\r\n) %}\r\n<p style=\"margin:0 0 4px 0; font-size:9px;\">\r\n    {{ cust_addr.address_line1 or \"\" }}<br>\r\n    {% if cust_addr.address_line2 %}{{ cust_addr.address_line2 }}<br>{% endif %}\r\n    {{ cust_addr.city or \"\" }}<br>\r\n    {{ cust_addr.country or \"\" }}{% if cust_addr.pincode %} - {{ cust_addr.pincode }}{% endif %}\r\n</p>\r\n{% endif %}\r\n\r\n<p style=\"margin:0 0 4px 0; font-size:9px;\">\r\nContact: {{ frappe.db.get_value(\"Customer\", doc.customer, \"mobile_no\") or \"\" }}\r\n</p>\r\n\r\n<p style=\"margin:0 0 4px 0; font-size:9px;\">\r\nEmail: {{ frappe.db.get_value(\"Customer\", doc.customer, \"email_id\") or \"\" }}\r\n</p>\r\n\r\n<p style=\"margin:0; font-weight:bold;\">\r\nTRN : {{ doc.tax_id }}\r\n</p>\r\n\r\n</td>\r\n\r\n\r\n<td width=\"26%\" style=\"vertical-align:top;\">\r\n\r\n<p style=\"margin:0;\">Invoice Details</p>\r\n\r\n<table style=\"width:100%; border-collapse:collapse; font-size:10px; margin:0;\">\r\n\r\n<tr>\r\n<td style=\"white-space:nowrap; padding:2px 0 !important; line-height:1.15;\">Invoice No</td>\r\n<td style=\"text-align:center; padding:2px 0 !important; line-height:1.15;\">:</td>\r\n<td style=\"padding:2px 0 !important; line-height:1.15;\">{{ doc.name }}</td>\r\n</tr>\r\n\r\n<tr>\r\n<td style=\"white-space:nowrap; padding:2px 0 !important; line-height:1.15;\">Invoice Date</td>\r\n<td style=\"text-align:center; padding:2px 0 !important; line-height:1.15;\">:</td>\r\n<td style=\"padding:2px 0 !important; line-height:1.15;\">\r\n{{ frappe.utils.formatdate(doc.posting_date, \"dd-MM-yyyy\") }}\r\n</td>\r\n</tr>\r\n\r\n<tr>\r\n<td style=\"white-space:nowrap; padding:2px 0 !important; line-height:1.15;\">Due Date</td>\r\n<td style=\"text-align:center; padding:2px 0 !important; line-height:1.15;\">:</td>\r\n<td style=\"padding:2px 0 !important; line-height:1.15;\">\r\n{{ frappe.utils.formatdate(doc.due_date, \"dd-MM-yyyy\") }}\r\n</td>\r\n</tr>\r\n\r\n{% if doc.custom_po_number %}\r\n<tr>\r\n<td style=\"white-space:nowrap; padding:2px 0 !important; line-height:1.15;\">Customer PO Ref.</td>\r\n<td style=\"text-align:center; padding:2px 0 !important; line-height:1.15;\">:</td>\r\n<td style=\"padding:2px 0 !important; line-height:1.15;\">{{ doc.custom_po_number }}</td>\r\n</tr>\r\n{% endif %}\r\n\r\n{% if doc.custom_contract_ref %}\r\n<tr>\r\n<td style=\"white-space:nowrap; padding:2px 0 !important; line-height:1.15;\">Contract Ref.</td>\r\n<td style=\"text-align:center; padding:2px 0 !important; line-height:1.15;\">:</td>\r\n<td style=\"padding:2px 0 !important; line-height:1.15;\">{{ doc.custom_contract_ref }}</td>\r\n</tr>\r\n{% endif %}\r\n\r\n{% if doc.custom_tax_invoice_number %}\r\n<tr>\r\n<td style=\"white-space:nowrap; padding:2px 0 !important; line-height:1.15;\">Operation Month</td>\r\n<td style=\"text-align:center; padding:2px 0 !important; line-height:1.15;\">:</td>\r\n<td style=\"padding:2px 0 !important; line-height:1.15;\">{{ doc.custom_tax_invoice_number }}</td>\r\n</tr>\r\n{% endif %}\r\n\r\n{% if doc.custom_project_ref %}\r\n<tr>\r\n<td style=\"white-space:nowrap; padding:2px 0 !important; line-height:1.15;\">Project/Site Ref.</td>\r\n<td style=\"text-align:center; padding:2px 0 !important; line-height:1.15;\">:</td>\r\n<td style=\"padding:2px 0 !important; line-height:1.15;\">{{ doc.custom_project_ref }}</td>\r\n</tr>\r\n{% endif %}\r\n{% if doc.custom_department_ref %}\r\n<tr>\r\n<td style=\"white-space:nowrap; padding:2px 0 !important; line-height:1.15;\">Department Ref#</td>\r\n<td style=\"text-align:center; padding:2px 0 !important; line-height:1.15;\">:</td>\r\n<td style=\"padding:2px 0 !important; line-height:1.15;\">{{ doc.custom_department_ref }}</td>\r\n</tr>\r\n{% endif %}\r\n{% if doc.custom_grn_ref %}\r\n<tr>\r\n<td style=\"white-space:nowrap; padding:2px 0 !important; line-height:1.15;\">GRN Ref.</td>\r\n<td style=\"text-align:center; padding:2px 0 !important; line-height:1.15;\">:</td>\r\n<td style=\"padding:2px 0 !important; line-height:1.15;\">{{ doc.custom_grn_ref }}</td>\r\n</tr>\r\n{% endif %}\r\n\r\n</table>\r\n\r\n</td>\r\n\r\n</tr>\r\n</table>\r\n\r\n\r\n<table class=\"items-table\" style=\"font-size:9px; table-layout:fixed; width:100%;\">\r\n\r\n<thead>\r\n\r\n<tr>\r\n\r\n<th width=\"5%\"  style=\"text-align:center; white-space:nowrap; font-weight:bold;\"><b>#</b></th>\r\n<th width=\"38%\" style=\"text-align:left; font-weight:bold;\"><b>Item</b></th>\r\n<th width=\"10%\"  style=\"text-align:center; white-space:nowrap; font-weight:bold;\"><b><center>Tax Rate</center></b></th>\r\n<th width=\"10%\"  style=\"text-align:center; white-space:nowrap; font-weight:bold;\"><b><center>Quantity</center><b></th>\r\n<th width=\"9%\" style=\"text-align:center; white-space:nowrap; font-weight:bold;\"><b>Rate</b></th>\r\n<th width=\"10%\" style=\"text-align:center; white-space:nowrap; font-weight:bold;\"><b>Amount</b></th>\r\n<th width=\"10%\" style=\"text-align:center; white-space:nowrap; font-weight:bold;\"><b>TAX</b></th>\r\n<th width=\"10%\" style=\"text-align:center; white-space:nowrap; font-weight:bold;\"><b>Total</b></th>\r\n\r\n</tr>\r\n\r\n</thead>\r\n\r\n<tbody>\r\n\r\n{% for item in doc.items %}\r\n\r\n<tr>\r\n\r\n<td style=\"text-align:center; white-space:nowrap; font-size:9px;\">\r\n{{ loop.index }}\r\n</td>\r\n\r\n<td style=\"font-size:9px; line-height:1.2; word-break:break-word;\">\r\n\r\n<span style=\"font-size:9px;\">\r\n{{ frappe.utils.strip_html(item.description) }}\r\n</span>\r\n\r\n{% if item.custom_vehicle %}\r\n<br/>\r\nVehicle No: {{ item.custom_vehicle }}\r\n{% endif %}\r\n\r\n</td>\r\n\r\n<td style=\"text-align:center; white-space:nowrap; font-size:9px;\">\r\n{{ item.tax_rate }}%\r\n</td>\r\n\r\n<td style=\"text-align:center; white-space:nowrap; font-size:9px;\">\r\n{{ item.qty }}\r\n{% if item.uom == \"Month\" %}\r\nMth\r\n{% elif item.uom == \"Hour\" %}\r\nHr\r\n{% else %}\r\n{{ item.uom }}\r\n{% endif %}\r\n</td>\r\n\r\n<td style=\"text-align:right; white-space:nowrap; font-size:9px;\">\r\n{{ \"{:,.2f}\".format(item.rate) }}\r\n</td>\r\n\r\n<td style=\"text-align:right; white-space:nowrap; font-size:9px;\">\r\n{{ \"{:,.2f}\".format(item.amount) }}\r\n</td>\r\n\r\n<td style=\"text-align:right; white-space:nowrap; font-size:9px;\">\r\n{{ \"{:,.2f}\".format(item.tax_amount) }}\r\n</td>\r\n\r\n<td style=\"text-align:right; white-space:nowrap; font-size:9px;\">\r\n{{ \"{:,.2f}\".format(item.total_amount) }}\r\n</td>\r\n\r\n</tr>\r\n\r\n{% endfor %}\r\n\r\n</tbody>\r\n\r\n</table>\r\n<br>\r\n\r\n<div style=\"width:100%; font-size:10px; margin:0; padding:0;\">\r\n\r\n<!-- TOP RIGHT (AMOUNT) -->\r\n<div style=\"width:40%; float:right; line-height:1.5; font-size:9px;\">\r\n\r\n<div style=\"margin-bottom:2px;\">\r\n<span style=\"display:inline-block; width:130px;\">Amount</span>\r\n<span style=\"display:inline-block; width:10px;\">:</span>\r\n<span style=\"display:inline-block; width:120px; text-align:right;\">\r\n{{ frappe.utils.fmt_money(doc.total) }} AED\r\n</span>\r\n</div>\r\n\r\n<div style=\"margin-bottom:2px;\">\r\n<span style=\"display:inline-block; width:130px;\">TAX (5%)</span>\r\n<span style=\"display:inline-block; width:10px;\">:</span>\r\n<span style=\"display:inline-block; width:120px; text-align:right;\">\r\n{{ frappe.utils.fmt_money(doc.total_taxes_and_charges) }} AED\r\n</span>\r\n</div>\r\n\r\n<div style=\"\r\nbackground-color:#6bbf2a !important;\r\ncolor:#ffffff !important;\r\nfont-weight:bold;\r\npadding:4px 0px;\r\nmargin-top:3px;\r\ndisplay:block;\r\n-webkit-print-color-adjust: exact !important;\r\nprint-color-adjust: exact !important;\r\n\">\r\n\r\n<span style=\"display:inline-block; width:130px; color:#ffffff !important;\">\r\nTotal (AED)\r\n</span>\r\n\r\n<span style=\"display:inline-block; width:10px; color:#ffffff !important;\">\r\n:\r\n</span>\r\n\r\n<span style=\"display:inline-block; width:120px; text-align:right; color:#ffffff !important;\">\r\n{{ frappe.utils.fmt_money(doc.grand_total) }} AED\r\n</span>\r\n\r\n</div>\r\n\r\n</div>\r\n\r\n\r\n<!-- CLEAR FLOAT -->\r\n<div style=\"clear:both;\"></div>\r\n\r\n\r\n<!-- LEFT (BANK) + RIGHT (WORDS) -->\r\n<div style=\"width:100%; margin-top:4px;\">\r\n\r\n<!-- LEFT -->\r\n<div style=\"width:60%; float:left; line-height:1.2;\">\r\n\r\n{% set bank = frappe.db.get_value(\r\n    \"Bank Account\",\r\n    {\"company\": doc.company, \"is_company_account\": 1,\"is_default\":1},\r\n    [\"account_name\", \"bank_account_no\", \"bank\", \"iban\", \"branch_code\"],\r\n    as_dict=True\r\n) %}\r\n\r\n{% set swift_code = frappe.db.get_value(\r\n    \"Bank\",\r\n    bank.bank,\r\n    \"swift_number\"\r\n) if bank and bank.bank else \"\" %}\r\n\r\n<p style=\"margin:0 0 6px 0; font-weight:bold;font-size:12px\">\r\nPlease remit payment to\r\n</p>\r\n\r\n<div>\r\n<span style=\"display:inline-block; width:120px;\">Account Name</span>\r\n<span style=\"display:inline-block; width:10px;\">:</span>\r\n<span>{{ bank.account_name if bank else doc.company }}</span>\r\n</div>\r\n\r\n<div>\r\n<span style=\"display:inline-block; width:120px;\">Account No</span>\r\n<span style=\"display:inline-block; width:10px;\">:</span>\r\n<span>{{ bank.bank_account_no if bank else \"\" }}</span>\r\n</div>\r\n\r\n<div>\r\n<span style=\"display:inline-block; width:120px;\">Bank Name</span>\r\n<span style=\"display:inline-block; width:10px;\">:</span>\r\n<span>{{ bank.bank if bank else \"\" }}</span>\r\n</div>\r\n\r\n<div>\r\n<span style=\"display:inline-block; width:120px;\">IBAN</span>\r\n<span style=\"display:inline-block; width:10px;\">:</span>\r\n<span>{{ bank.iban if bank else \"\" }}</span>\r\n</div>\r\n\r\n<div>\r\n<span style=\"display:inline-block; width:120px;\">Swift Code</span>\r\n<span style=\"display:inline-block; width:10px;\">:</span>\r\n<span>{{ swift_code or \"\" }}</span>\r\n</div>\r\n\r\n<div>\r\n<span style=\"display:inline-block; width:120px;\">Branch</span>\r\n<span style=\"display:inline-block; width:10px;\">:</span>\r\n<span>{{ bank.branch_code if bank else \"\" }}</span>\r\n</div>\r\n\r\n</div>\r\n\r\n<!-- RIGHT -->\r\n<div style=\"width:40%; float:right; line-height:1.3;\">\r\n\r\n<p style=\"margin:0 0 4px 0;\">Total (in words):</p>\r\n\r\n<p style=\"margin:0; font-weight:bold;\">\r\n{{ doc.in_words }}\r\n</p>\r\n\r\n</div>\r\n\r\n<div style=\"clear:both;\"></div>\r\n\r\n</div>\r\n\r\n</div>\r\n\r\n\r\n<br>\r\n<p style=\"margin:0 0 6px 0; font-weight:bold;font-size:12px\">\r\nTax Summary\r\n</p>\r\n<table style=\"width:100%; border-collapse:collapse; text-align:center; font-size:9px; margin: 0 !important;\r\n    padding: 0 !important;\r\n    line-height: 0.9 !important;\">\r\n<thead>\r\n\r\n<tr style=\"background:#cce7d5; text-align:center; font-weight:bold; margin: 0 !important;\r\n    padding: 0 !important;\r\n    line-height: 0.9 !important;\r\n    \">\r\n<th style=\"border:1px solid #ccc; padding:4px;text-align:center; margin: 0 margin: 6px !important;\r\n    padding: 4px !important;\r\n    line-height: 1 !important;\r\n    font-size: 8px !important;\"><center><b>Tax Rate</b></center></th>\r\n<th colspan=\"2\" style=\"border:1px solid #ccc; padding:4px;text-align:cente; margin: 6px !important;\r\n    padding: 4px !important;\r\n    line-height: 1 !important;\r\n    font-size: 8px !important;\"><center><b>TAX</b></center></th>\r\n<th style=\"border:1px solid #ccc; padding:4px;text-align:center; margin: 6px !important;\r\n    padding: 4px !important;\r\n    line-height: 1 !important;\r\n    font-size: 8px !important;\"><center><b>Total</b></center></th>\r\n</tr>\r\n\r\n<tr style=\"background:#cce7d5; text-align:center; font-weight:bold;margin: 6px !important;\r\n    padding: 4px !important;\r\n    line-height: 1 !important;\r\n    font-size: 8px !important;\">\r\n<th style=\"border:1px solid #ccc; padding:3px;margin: 6px !important;\r\n    padding: 4px !important;\r\n    line-height: 1 !important;\r\n    font-size: 8px !important;\"></th>\r\n<th style=\"border:1px solid #ccc; padding:3px;text-align:center;margin: 6px !important;\r\n    padding: 4px !important;\r\n    line-height: 1 !important;\r\n    font-size: 8px !important;\"><center><b>Rate</b></center></th>\r\n<th style=\"border:1px solid #ccc; padding:3px;text-align:center;margin: 6px !important;\r\n    padding: 4px !important;\r\n    line-height: 1 !important;\r\n    font-size: 8px !important;\"><center><b>Amount</b></center></th>\r\n<th style=\"border:1px solid #ccc; padding:3px;margin: 6px !important;\r\n    padding: 4px !important;\r\n    line-height: 1 !important;\r\n    font-size: 8px !important;\"></th>\r\n</tr>\r\n\r\n</thead>\r\n\r\n<tbody>\r\n\r\n{% for tax in doc.taxes %}\r\n\r\n<tr>\r\n\r\n<td style=\"border:1px solid #ccc; text-align:center; padding:3px;margin: 6px !important;\r\n    padding: 4px !important;\r\n    line-height: 1 !important;\r\n    font-size: 8px !important;\">\r\n{{ tax.rate }}%\r\n</td>\r\n\r\n<td style=\"border:1px solid #ccc; text-align:center; padding:3px;margin: 6px !important;\r\n    padding: 4px !important;\r\n    line-height: 1 !important;\r\n    font-size: 8px !important;\">\r\n{{ tax.rate }}%\r\n</td>\r\n\r\n<td style=\"border:1px solid #ccc; text-align:right; padding:3px;margin: 6px !important;\r\n    padding: 4px !important;\r\n    line-height: 1 !important;\r\n    font-size: 8px !important;\">\r\n{{ \"{:,.2f}\".format(tax.tax_amount) }}\r\n</td>\r\n\r\n<td style=\"border:1px solid #ccc; text-align:right; padding:3px;margin: 6px !important;\r\n    padding: 4px !important;\r\n    line-height: 1 !important;\r\n    font-size: 8px !important;\">\r\n {{ \"{:,.2f}\".format(tax.tax_amount) }}\r\n</td>\r\n\r\n</tr>\r\n\r\n{% endfor %}\r\n\r\n<tr style=\"font-weight:bold;\">\r\n\r\n<td style=\"border:1px solid #ccc; padding:3px;margin: 6px !important;\r\n    padding: 4px !important;\r\n    line-height: 1 !important;\r\n    font-size: 8px !important;\">Total</td>\r\n\r\n<td style=\"border:1px solid #ccc;margin: 6px !important;\r\n    padding: 4px !important;\r\n    line-height: 1 !important;\r\n    font-size: 8px !important;\"></td>\r\n\r\n<td style=\"border:1px solid #ccc; text-align:right; padding:3px;margin: 6px !important;\r\n    padding: 4px !important;\r\n    line-height: 1 !important;\r\n    font-size: 8px !important;\">\r\n{{ \"{:,.2f}\".format(doc.total_taxes_and_charges) }}\r\n</td>\r\n\r\n<td style=\"border:1px solid #ccc; text-align:right; padding:3px;margin: 6px !important;\r\n    padding: 4px !important;\r\n    line-height: 1 !important;\r\n    font-size: 8px !important;\">\r\n{{ \"{:,.2f}\".format(doc.total_taxes_and_charges) }}\r\n</td>\r\n\r\n</tr>\r\n\r\n<tr>\r\n\r\n<td colspan=\"4\" style=\"border:1px solid #ccc; padding:4px;text-align:left;margin: 6px !important;\r\n    padding: 4px !important;\r\n    line-height: 1 !important;\r\n    font-size: 8px !important;\">\r\n\r\nTotal Tax In Words:<b>\r\n{{ frappe.utils.money_in_words(doc.total_taxes_and_charges, doc.currency) }}</b>\r\n\r\n</td>\r\n\r\n</tr>\r\n\r\n</tbody>\r\n\r\n</table>\r\n\r\n\r\n<br>\r\n\r\n\r\n<b style=\"font-size:12px\">Terms and Conditions:</b>\r\n\r\n<ol style=\"font-size:10px; line-height:1.4;\">\r\n\r\n<li>\r\nAny dispute or discrepancy relating to this invoice must be notified in writing to\r\n<a href=\"mailto:accounts@oriongroup.ae\" style=\"color:blue;\">accounts@oriongroup.ae</a> within 7 days from invoice submission date.\r\n</li>\r\n\r\n<li>\r\nPayment should be made within 30 days from invoice submission date.\r\n</li>\r\n\r\n</ol>\r\n\r\n<div id=\"footer-html\" class=\"visible-pdf\" style=\"width:100%; padding:0 6px;\">\r\n\r\n    <div class=\"letter-head-footer\" style=\"position:relative; width:100%; font-size:9px;\">\r\n\r\n        <div style=\"border-top:1px dashed #999; margin:3px 0;\"></div>\r\n\r\n        <!-- Invoice No -->\r\n        <div style=\"position:absolute; left:0;white-space:nowrap;\">\r\n            <div>Invoice No</div>\r\n            <div style=\"font-weight:bold;\">{{ doc.name }}</div>\r\n        </div>\r\n\r\n        <!-- Invoice Date (closer now) -->\r\n        <div style=\"position:absolute; left:60px;white-space:nowrap;\">\r\n            <div>Invoice Date</div>\r\n            <div style=\"font-weight:bold;\">\r\n                {{ frappe.utils.formatdate(doc.posting_date) }}\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Billed To (closer now) -->\r\n        <div style=\"position:absolute; left:120px;\">\r\n            <div>Billed To</div>\r\n            <div style=\"font-weight:bold;white-space:nowrap;\">\r\n                {{ doc.customer }}\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Page No -->\r\n        <div style=\"position:absolute; right:4px; font-weight:bold; white-space:nowrap;\">\r\n            {{ _(\"Page {0} of {1}\").format('<span class=\"page\"></span>', '<span class=\"topage\"></span>') }}\r\n        </div>\r\n\r\n        <div style=\"height:32px;\"></div>\r\n\r\n        <div style=\"text-align:center; font-size:7px; margin-top:2px;\">\r\n            This is an electronically generated document, no signature is required.\r\n        </div>\r\n\r\n    </div>\r\n\r\n</div>",
