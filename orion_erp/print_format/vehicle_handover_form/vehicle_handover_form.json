 "html": "<style>\r\n\r\n@media screen {\r\n    .print-format {\r\n        width: 9.4in;\r\n        padding: 0.1in;\r\n        min-height: 11.7in;\r\n    }\r\n}\r\n\r\nbody {\r\n    margin: 0 !important;\r\n    padding: 0 !important;\r\n    font-family: Arial, sans-serif;\r\n}\r\n\r\ntable {\r\n    width: 100%;\r\n    border-collapse: collapse;\r\n    table-layout: fixed;\r\n}\r\n\r\ntd, th {\r\n    border: 1px solid #000;\r\n    padding: 5px;\r\n    font-size: 12px;\r\n    vertical-align: top;\r\n}\r\n\r\n.center { text-align: center; }\r\n.bold { font-weight: bold; }\r\n\r\n.grey { background: #e6e6e6; }\r\n\r\n.title {\r\n    font-size: 22px;\r\n    font-weight: bold;\r\n    text-align: center;\r\n}\r\n\r\n.sub-title {\r\n    text-align: center;\r\n    font-weight: bold;\r\n    color: #c00000;\r\n}\r\n\r\n.no-border {\r\n    border: none !important;\r\n}\r\n\r\n</style>\r\n{% set logo = frappe.db.get_single_value(\"Orion Settings\", \"company_logo\") %}\r\n{% set vehicle_handover_image = frappe.db.get_single_value(\"Orion Settings\", \"vehicle_handover_image\") %}\r\n\r\n<!-- ================= GET COMPANY VEHICLE ROW ================= -->\r\n{% set vehicle = namespace(row={}) %}\r\n\r\n{% for d in doc.asset_handover_detail %}\r\n    {% if d.asset_type == \"Company Vehicle\" %}\r\n        {% set vehicle.row = d %}\r\n    {% endif %}\r\n{% endfor %}\r\n\r\n<table style=\"\r\n    width:100%;\r\n    border-collapse:collapse;\r\n    table-layout:fixed;\r\n    font-family:Arial, sans-serif;\r\n    border:2px solid #6f8f2f;\r\n\">\r\n\r\n    <!-- ================= HEADER ================= -->\r\n    <!-- ================= HEADER ================= -->\r\n<tr>\r\n    <td colspan=\"4\" style=\"\r\n        padding:0;\r\n        height:80px;\r\n        vertical-align:middle;\r\n        border:none;\r\n    \">\r\n\r\n        <table style=\"\r\n            width:100%;\r\n            border-collapse:collapse;\r\n            border:none;\r\n        \">\r\n            <tr style=\"border:none;\">\r\n\r\n                <!-- LOGO -->\r\n                <td style=\"\r\n                    width:28%;\r\n                    padding:8px 15px;\r\n                    vertical-align:middle;\r\n                    border:none;\r\n                \">\r\n\r\n                    {% if logo %}\r\n                        <img src=\"{{ logo }}\" style=\"\r\n                            height:70px;\r\n                            display:block;\r\n                        \">\r\n                    {% endif %}\r\n\r\n                </td>\r\n\r\n                <!-- EMPTY SPACE -->\r\n                <td style=\"\r\n                    width:72%;\r\n                    border:none;\r\n                \"></td>\r\n\r\n            </tr>\r\n        </table>\r\n\r\n    </td>\r\n</tr>\r\n\r\n\r\n\r\n    <!-- ================= TITLE ================= -->\r\n    <tr>\r\n        <td colspan=\"4\" style=\"\r\n            background:#d7e0be;\r\n            text-align:center;\r\n            font-size:14px;\r\n            font-weight:bold;\r\n            padding:6px;\r\n            border-bottom:2px solid #000;\r\n        \">\r\n            Internal Vehicle Handover Form\r\n        </td>\r\n    </tr>\r\n\r\n    <!-- ================= ROW 1 ================= -->\r\n    <tr>\r\n\r\n        <td style=\"\r\n            width:25%;\r\n            padding:8px 10px;\r\n            font-size:12px;\r\n            font-weight:bold;\r\n            border-bottom:2px solid #6f8f2f;\r\n        \">\r\n            Vehicle No.\r\n        </td>\r\n\r\n        <td style=\"\r\n            width:25%;\r\n            padding:8px 10px;\r\n            font-size:11px;\r\n            border-right:2px solid #6f8f2f;\r\n            border-bottom:2px solid #6f8f2f;\r\n        \">\r\n            {{ vehicle.row.plate_number or \"\" }}\r\n        </td>\r\n\r\n        <td style=\"\r\n            width:25%;\r\n            padding:8px 10px;\r\n            font-size:12px;\r\n            font-weight:bold;\r\n            border-bottom:2px solid #6f8f2f;\r\n        \">\r\n            Name of last user\r\n        </td>\r\n\r\n        <td style=\"\r\n            width:25%;\r\n            padding:8px 10px;\r\n            font-size:11px;\r\n            border-bottom:2px solid #6f8f2f;\r\n        \">\r\n            {{ vehicle.row.name_of_last_user or \"\" }}\r\n        </td>\r\n\r\n    </tr>\r\n\r\n    <!-- ================= ROW 2 ================= -->\r\n    <tr>\r\n\r\n        <td style=\"\r\n            padding:8px 10px;\r\n            font-size:12px;\r\n            font-weight:bold;\r\n            border-bottom:2px solid #6f8f2f;\r\n        \">\r\n            Department\r\n        </td>\r\n\r\n        <td style=\"\r\n            padding:8px 10px;\r\n            font-size:11px;\r\n            border-right:2px solid #6f8f2f;\r\n            border-bottom:2px solid #6f8f2f;\r\n        \">\r\n            {{ doc.department or \"\" }}\r\n        </td>\r\n\r\n        <td style=\"\r\n            padding:8px 10px;\r\n            font-size:12px;\r\n            font-weight:bold;\r\n            border-bottom:2px solid #6f8f2f;\r\n        \">\r\n            Odometer\r\n        </td>\r\n\r\n        <td style=\"\r\n            padding:8px 10px;\r\n            font-size:11px;\r\n            border-bottom:2px solid #6f8f2f;\r\n        \">\r\n            {{ vehicle.row.odometer_reading_at_issue or \"\" }}\r\n\r\n            <span style=\"\r\n                float:right;\r\n                font-style:italic;\r\n                font-size:11px;\r\n            \">\r\n                Kms\r\n            </span>\r\n        </td>\r\n\r\n    </tr>\r\n\r\n    <!-- ================= VEHICLE TYPE HEADER ================= -->\r\n    <tr>\r\n        <td colspan=\"4\" style=\"\r\n            background:#556f1f;\r\n            color:#fff;\r\n            text-align:center;\r\n            font-size:13px;\r\n            font-weight:bold;\r\n            padding:6px;\r\n        \">\r\n            Type of Vehicle\r\n        </td>\r\n    </tr>\r\n\r\n    <!-- ================= VEHICLE IMAGE ================= -->\r\n    <tr>\r\n        <td colspan=\"4\" style=\"\r\n            padding:0;\r\n            text-align:center;\r\n            border-bottom:2px solid #6f8f2f;\r\n        \">\r\n\r\n            {% if vehicle_handover_image %}\r\n                <img src=\"{{ vehicle_handover_image }}\" style=\"\r\n                    width:100%;\r\n                    display:block;\r\n                \">\r\n            {% endif %}\r\n\r\n        </td>\r\n    </tr>\r\n    <!-- ================= ACCESSORIES HEADER ================= -->\r\n<tr>\r\n    <td colspan=\"4\" style=\"\r\n        background:#556f1f;\r\n        color:#fff;\r\n        font-size:12px;\r\n        font-weight:bold;\r\n        padding:6px 10px;\r\n        border-top:2px solid #6f8f2f;\r\n        border-bottom:2px solid #6f8f2f;\r\n    \">\r\n        Accessories delivered along with the vehicle:\r\n    </td>\r\n</tr>\r\n\r\n<!-- ================= TABLE HEADER ================= -->\r\n<tr>\r\n\r\n    <td style=\"\r\n        width:35%;\r\n        text-align:center;\r\n        font-size:11px;\r\n        font-weight:bold;\r\n        padding:4px;\r\n        border-right:2px solid #6f8f2f;\r\n        border-bottom:2px solid #6f8f2f;\r\n    \">\r\n        Items\r\n    </td>\r\n\r\n    <td style=\"\r\n        width:15%;\r\n        text-align:center;\r\n        font-size:11px;\r\n        font-weight:bold;\r\n        border-right:2px solid #6f8f2f;\r\n        border-bottom:2px solid #6f8f2f;\r\n    \">\r\n        \u2713 &nbsp;&nbsp;&nbsp;&nbsp; \u2716 &nbsp;&nbsp;&nbsp;&nbsp; NA\r\n    </td>\r\n\r\n    <td style=\"\r\n        width:35%;\r\n        text-align:center;\r\n        font-size:11px;\r\n        font-weight:bold;\r\n        padding:4px;\r\n        border-right:2px solid #6f8f2f;\r\n        border-bottom:2px solid #6f8f2f;\r\n    \">\r\n        Items\r\n    </td>\r\n\r\n    <td style=\"\r\n        width:15%;\r\n        text-align:center;\r\n        font-size:11px;\r\n        font-weight:bold;\r\n        border-bottom:2px solid #6f8f2f;\r\n    \">\r\n        \u2713 &nbsp;&nbsp;&nbsp;&nbsp; \u2716 &nbsp;&nbsp;&nbsp;&nbsp; NA\r\n    </td>\r\n\r\n</tr>\r\n\r\n<!-- ================= ACCESSORIES ROWS ================= -->\r\n\r\n<tr>\r\n    <td style=\"padding:4px 8px;font-size:10px;border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\">Mulkiya</td>\r\n    <td style=\"border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\"></td>\r\n\r\n    <td style=\"padding:4px 8px;font-size:10px;border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\">Desert Kit (pickup)</td>\r\n    <td style=\"border-bottom:2px solid #6f8f2f;\"></td>\r\n</tr>\r\n\r\n<tr>\r\n    <td style=\"padding:4px 8px;font-size:10px;border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\">Vehicle CICPA Pass</td>\r\n    <td style=\"border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\"></td>\r\n\r\n    <td style=\"padding:4px 8px;font-size:10px;border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\">Flag Pole (pickup)</td>\r\n    <td style=\"border-bottom:2px solid #6f8f2f;\"></td>\r\n</tr>\r\n\r\n<tr>\r\n    <td style=\"padding:4px 8px;font-size:10px;border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\">Tool Box</td>\r\n    <td style=\"border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\"></td>\r\n\r\n    <td style=\"padding:4px 8px;font-size:10px;border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\">Ghadeer Card (drinking tanker)</td>\r\n    <td style=\"border-bottom:2px solid #6f8f2f;\"></td>\r\n</tr>\r\n\r\n<tr>\r\n    <td style=\"padding:4px 8px;font-size:10px;border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\">First Aid Kit</td>\r\n    <td style=\"border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\"></td>\r\n\r\n    <td style=\"padding:4px 8px;font-size:10px;border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\">Tablet (Sewage & drinking tanker)</td>\r\n    <td style=\"border-bottom:2px solid #6f8f2f;\"></td>\r\n</tr>\r\n\r\n<tr>\r\n    <td style=\"padding:4px 8px;font-size:10px;border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\">Fire Extinguisher</td>\r\n    <td style=\"border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\"></td>\r\n\r\n    <td style=\"padding:4px 8px;font-size:10px;border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\">Hose Pipe (Tanker)</td>\r\n    <td style=\"border-bottom:2px solid #6f8f2f;\"></td>\r\n</tr>\r\n\r\n<tr>\r\n    <td style=\"padding:4px 8px;font-size:10px;border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\">Safety Triangles</td>\r\n    <td style=\"border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\"></td>\r\n\r\n    <td style=\"padding:4px 8px;font-size:10px;border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\">Spill Kit (Sewage & diesel tanker)</td>\r\n    <td style=\"border-bottom:2px solid #6f8f2f;\"></td>\r\n</tr>\r\n\r\n<tr>\r\n    <td style=\"padding:4px 8px;font-size:10px;border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\">Spare Tyre</td>\r\n    <td style=\"border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\"></td>\r\n\r\n    <td style=\"border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\"></td>\r\n    <td style=\"border-bottom:2px solid #6f8f2f;\"></td>\r\n</tr>\r\n\r\n<tr>\r\n    <td style=\"padding:4px 8px;font-size:10px;border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\">Wheel Stopper</td>\r\n    <td style=\"border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\"></td>\r\n\r\n    <td style=\"border-right:2px solid #6f8f2f;border-bottom:2px solid #6f8f2f;\"></td>\r\n    <td style=\"border-bottom:2px solid #6f8f2f;\"></td>\r\n</tr>\r\n\r\n<!-- ================= BLANK SPACE ================= -->\r\n<tr>\r\n    <td colspan=\"4\" style=\"\r\n        height:30px;\r\n        border-bottom:2px solid #6f8f2f;\r\n    \"></td>\r\n</tr>\r\n\r\n<!-- ================= INTERIOR DEFECTS ================= -->\r\n<tr>\r\n    <td colspan=\"4\" style=\"\r\n        padding:4px 10px;\r\n        font-size:11px;\r\n        font-weight:bold;\r\n        text-decoration:underline;\r\n        border-bottom:2px solid #6f8f2f;\r\n    \">\r\n        Interior Defects & Damages, if any:\r\n    </td>\r\n</tr>\r\n\r\n{% for i in range(4) %}\r\n<tr>\r\n    <td colspan=\"2\" style=\"\r\n        height:18px;\r\n        border-right:2px solid #6f8f2f;\r\n        border-bottom:2px solid #6f8f2f;\r\n    \"></td>\r\n\r\n    <td colspan=\"2\" style=\"\r\n        border-bottom:2px solid #6f8f2f;\r\n    \"></td>\r\n</tr>\r\n{% endfor %}\r\n\r\n<!-- ================= EXTERIOR DEFECTS ================= -->\r\n<tr>\r\n    <td colspan=\"4\" style=\"\r\n        padding:4px 10px;\r\n        font-size:11px;\r\n        font-weight:bold;\r\n        text-decoration:underline;\r\n        border-bottom:2px solid #6f8f2f;\r\n    \">\r\n        Exterior Defects & Damages, if any:\r\n    </td>\r\n</tr>\r\n\r\n{% for i in range(4) %}\r\n<tr>\r\n    <td colspan=\"2\" style=\"\r\n        height:18px;\r\n        border-right:2px solid #6f8f2f;\r\n        border-bottom:2px solid #6f8f2f;\r\n    \"></td>\r\n\r\n    <td colspan=\"2\" style=\"\r\n        border-bottom:2px solid #6f8f2f;\r\n    \"></td>\r\n</tr>\r\n{% endfor %}\r\n\r\n<!-- ================= DECLARATION ================= -->\r\n<tr>\r\n    <td colspan=\"4\" style=\"\r\n        background:#556f1f;\r\n        color:#fff;\r\n        font-size:12px;\r\n        font-weight:bold;\r\n        padding:6px 10px;\r\n        border-top:2px solid #6f8f2f;\r\n    \">\r\n        Declaration:\r\n    </td>\r\n</tr>\r\n<!-- ================= DECLARATION TEXT ================= -->\r\n<tr>\r\n\r\n    <td colspan=\"2\" style=\"\r\n        padding:10px;\r\n        font-size:11px;\r\n        font-weight:bold;\r\n        border-right:2px solid #6f8f2f;\r\n        border-bottom:2px solid #6f8f2f;\r\n    \">\r\n        The above mentioned vehicle is handed over on\r\n    </td>\r\n\r\n    <td style=\"\r\n        padding:8px 12px;\r\n        border-right:2px solid #6f8f2f;\r\n        border-bottom:2px solid #6f8f2f;\r\n    \">\r\n\r\n        <div style=\"\r\n            border:2px solid #556f1f;\r\n            padding:8px 10px;\r\n            font-size:10px;\r\n            height:28px;\r\n        \">\r\n            Date:\r\n        </div>\r\n\r\n    </td>\r\n\r\n    <td style=\"\r\n        padding:8px 12px;\r\n        border-bottom:2px solid #6f8f2f;\r\n    \">\r\n\r\n        <div style=\"\r\n            border:2px solid #556f1f;\r\n            padding:8px 10px;\r\n            font-size:10px;\r\n            height:28px;\r\n        \">\r\n            Time:\r\n            <span style=\"float:right;\">AM/PM</span>\r\n        </div>\r\n\r\n    </td>\r\n\r\n</tr>\r\n\r\n<!-- ================= SIGNATURE HEADER ================= -->\r\n<tr>\r\n\r\n    <td style=\"\r\n        background:#556f1f;\r\n        color:#fff;\r\n        font-size:11px;\r\n        font-weight:bold;\r\n        padding:4px 10px;\r\n        border-right:2px solid #6f8f2f;\r\n    \">\r\n        Handed over by:\r\n    </td>\r\n\r\n    <td style=\"\r\n        background:#556f1f;\r\n        color:#fff;\r\n        font-size:11px;\r\n        font-weight:bold;\r\n        padding:4px 10px;\r\n        border-right:2px solid #6f8f2f;\r\n    \">\r\n        Approved by:\r\n    </td>\r\n\r\n    <td colspan=\"2\" style=\"\r\n        background:#556f1f;\r\n        color:#fff;\r\n        font-size:11px;\r\n        font-weight:bold;\r\n        padding:4px 10px;\r\n    \">\r\n        Received by:\r\n    </td>\r\n\r\n</tr>\r\n\r\n<!-- ================= DETAILS ROW 1 ================= -->\r\n<tr>\r\n\r\n    <td style=\"\r\n        padding:6px 10px;\r\n        font-size:10px;\r\n        font-weight:bold;\r\n        border-right:2px solid #6f8f2f;\r\n        border-bottom:2px solid #6f8f2f;\r\n    \">\r\n        Name:\r\n    </td>\r\n\r\n    <td rowspan=\"3\" style=\"\r\n        vertical-align:top;\r\n        padding:10px;\r\n        border-right:2px solid #6f8f2f;\r\n        border-bottom:2px solid #6f8f2f;\r\n    \">\r\n        <div style=\"\r\n            font-size:10px;\r\n            font-weight:bold;\r\n            margin-bottom:8px;\r\n        \">\r\n            Workshop Supervisor:\r\n        </div>\r\n    </td>\r\n\r\n    <td colspan=\"2\" style=\"\r\n        padding:6px 10px;\r\n        font-size:10px;\r\n        font-weight:bold;\r\n        border-bottom:2px solid #6f8f2f;\r\n    \">\r\n        Name: {{doc.employee_name}}\r\n    </td>\r\n\r\n</tr>\r\n\r\n<!-- ================= DETAILS ROW 2 ================= -->\r\n<tr>\r\n\r\n    <td style=\"\r\n        padding:6px 10px;\r\n        font-size:10px;\r\n        font-weight:bold;\r\n        border-right:2px solid #6f8f2f;\r\n        border-bottom:2px solid #6f8f2f;\r\n    \">\r\n        Emp. ID:\r\n    </td>\r\n\r\n    <td colspan=\"2\" style=\"\r\n        padding:6px 10px;\r\n        font-size:10px;\r\n        font-weight:bold;\r\n        border-bottom:2px solid #6f8f2f;\r\n    \">\r\n        Emp. ID: {{doc.employee}}\r\n    </td>\r\n\r\n</tr>\r\n\r\n<!-- ================= DETAILS ROW 3 ================= -->\r\n<tr>\r\n\r\n    <td style=\"\r\n        padding:6px 10px;\r\n        font-size:10px;\r\n        font-weight:bold;\r\n        border-right:2px solid #6f8f2f;\r\n        border-bottom:2px solid #6f8f2f;\r\n    \">\r\n        Mob. No.\r\n    </td>\r\n\r\n    <td colspan=\"2\" style=\"\r\n        padding:6px 10px;\r\n        font-size:10px;\r\n        font-weight:bold;\r\n        border-bottom:2px solid #6f8f2f;\r\n    \">\r\n        Mob. No.\r\n    </td>\r\n\r\n</tr>\r\n\r\n<!-- ================= SIGNATURE AREA ================= -->\r\n<tr>\r\n\r\n    <td style=\"\r\n        height:100px;\r\n        vertical-align:top;\r\n        padding:6px 10px;\r\n        font-size:10px;\r\n        font-weight:bold;\r\n        font-style:italic;\r\n        border-right:2px solid #6f8f2f;\r\n    \">\r\n        Signature:\r\n    </td>\r\n\r\n    <td style=\"\r\n        height:100px;\r\n        vertical-align:top;\r\n        padding:6px 10px;\r\n        font-size:10px;\r\n        font-weight:bold;\r\n        font-style:italic;\r\n        border-right:2px solid #6f8f2f;\r\n    \">\r\n        Signature:\r\n    </td>\r\n\r\n    <td colspan=\"2\" style=\"\r\n        height:100px;\r\n        vertical-align:top;\r\n        padding:6px 10px;\r\n        font-size:10px;\r\n        font-weight:bold;\r\n        font-style:italic;\r\n    \">\r\n        Signature:\r\n    </td>\r\n\r\n</tr>\r\n</table>\r\n",
