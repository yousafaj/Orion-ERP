 "doc_type": "Job Offer",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<style>\r\n\r\n@media screen {\r\n    .print-format {\r\n        width: 9.4in;\r\n        padding: 0.1in;\r\n        min-height: 11.7in;\r\n    }\r\n}\r\n\r\nbody {\r\n    margin: 0 !important;\r\n    padding: 0 !important;\r\n    font-family: Arial, sans-serif;\r\n}\r\n\r\ntable {\r\n    width: 100%;\r\n    border-collapse: collapse;\r\n    table-layout: fixed;\r\n}\r\n\r\ntd, th {\r\n    border: 1px solid #000;\r\n    padding: 5px;\r\n    font-size: 12px;\r\n    vertical-align: top;\r\n}\r\n\r\n.center { text-align: center; }\r\n.bold { font-weight: bold; }\r\n\r\n.grey { background: #e6e6e6; }\r\n\r\n.title {\r\n    font-size: 22px;\r\n    font-weight: bold;\r\n    text-align: center;\r\n}\r\n\r\n.sub-title {\r\n    text-align: center;\r\n    font-weight: bold;\r\n    color: #c00000;\r\n}\r\n\r\n.no-border {\r\n    border: none !important;\r\n}\r\n\r\n</style>\r\n\r\n{% set logo = frappe.db.get_single_value(\"Orion Settings\", \"company_logo\") %}\r\n\r\n<div style=\"width:100%; font-family:Arial, sans-serif; border:1px solid #7f8c69;\">\r\n\r\n    <!-- ================= HEADER ================= -->\r\n    <table style=\"width:100%; border-collapse:collapse; table-layout:fixed;\">\r\n        <tr>\r\n\r\n            <!-- Logo -->\r\n            <td style=\"\r\n                width:22%;\r\n                height:70px;\r\n                padding:6px 10px;\r\n                border:none;\r\n                vertical-align:middle;\r\n            \">\r\n                {% if logo %}\r\n                    <img src=\"{{ logo }}\" \r\n                         style=\"height:58px; width:auto; display:block;\">\r\n                {% endif %}\r\n            </td>\r\n\r\n            <!-- Empty Space -->\r\n            <td style=\"\r\n                width:53%;\r\n                border:none;\r\n            \"></td>\r\n\r\n            <!-- Doc Ref -->\r\n            <td style=\"\r\n                width:25%;\r\n                text-align:right;\r\n                vertical-align:bottom;\r\n                padding:0 12px 6px 0;\r\n                border:none;\r\n                font-size:11px;\r\n                color:#666;\r\n            \">\r\n                Doc Ref : {{doc.name}}\r\n            </td>\r\n\r\n        </tr>\r\n    </table>\r\n\r\n    <!-- ================= TITLE ================= -->\r\n    <div style=\"\r\n        background:#d8e1bf;\r\n        text-align:center;\r\n        font-size:14px;\r\n        font-weight:bold;\r\n        padding:8px 0;\r\n        border-top:1px solid #7f8c69;\r\n        border-bottom:1px solid #7f8c69;\r\n        letter-spacing:0.3px;\r\n    \">\r\n        NEW RESIDENCE &amp; WORK PERMIT APPLICATION FORM\r\n    </div>\r\n\r\n    <!-- ================= BODY ================= -->\r\n    <table style=\"\r\n        width:100%;\r\n        border-collapse:collapse;\r\n        table-layout:fixed;\r\n    \">\r\n\r\n        <!-- Row 1 -->\r\n        <tr>\r\n\r\n            <td style=\"\r\n                width:20%;\r\n                background:#f1f1f1;\r\n                font-size:11px;\r\n                font-weight:bold;\r\n                padding:8px;\r\n                border:1px solid #7f8c69;\r\n            \">\r\n                Name of Candidate\r\n            </td>\r\n\r\n            <td style=\"\r\n                width:46%;\r\n                background:#ffffff;\r\n                font-size:11px;\r\n                padding:8px;\r\n                border:1px solid #7f8c69;\r\n            \">\r\n                {{ doc.applicant_name or \"\" }}\r\n            </td>\r\n\r\n            <td style=\"\r\n                width:16%;\r\n                background:#f1f1f1;\r\n                font-size:11px;\r\n                font-weight:bold;\r\n                padding:8px;\r\n                border:1px solid #7f8c69;\r\n            \">\r\n                Ref No.\r\n            </td>\r\n\r\n            <td style=\"\r\n                width:18%;\r\n                background:#ffffff;\r\n                font-size:11px;\r\n                padding:8px;\r\n                border:1px solid #7f8c69;\r\n            \">\r\n                {{ doc.custom_reference or doc.name }}\r\n            </td>\r\n\r\n        </tr>\r\n\r\n        <!-- Row 2 -->\r\n        <tr>\r\n\r\n            <td style=\"\r\n                background:#f1f1f1;\r\n                font-size:11px;\r\n                font-weight:bold;\r\n                padding:8px;\r\n                border:1px solid #7f8c69;\r\n            \">\r\n                Designation Offered\r\n            </td>\r\n\r\n            <td style=\"\r\n                background:#ffffff;\r\n                font-size:11px;\r\n                padding:8px;\r\n                border:1px solid #7f8c69;\r\n            \">\r\n                {{ doc.designation or \"\" }}\r\n            </td>\r\n\r\n            <td style=\"\r\n                background:#f1f1f1;\r\n                font-size:11px;\r\n                font-weight:bold;\r\n                padding:8px;\r\n                border:1px solid #7f8c69;\r\n            \">\r\n                Referred By\r\n            </td>\r\n\r\n            <td style=\"\r\n                background:#ffffff;\r\n                font-size:11px;\r\n                padding:8px;\r\n                border:1px solid #7f8c69;\r\n            \">\r\n                {{ doc.custom_referred_by or \"\" }}\r\n            </td>\r\n\r\n        </tr>\r\n\r\n        <!-- Row 3 -->\r\n        <tr>\r\n\r\n            <td style=\"\r\n                background:#f1f1f1;\r\n                font-size:11px;\r\n                font-weight:bold;\r\n                padding:8px;\r\n                border:1px solid #7f8c69;\r\n            \">\r\n                Type of Contract\r\n            </td>\r\n\r\n            <td style=\"\r\n                background:#ffffff;\r\n                font-size:11px;\r\n                padding:8px;\r\n                border:1px solid #7f8c69;\r\n            \">\r\n                {{ doc.custom_type_of_contract or \"\" }}\r\n            </td>\r\n\r\n            <td style=\"\r\n                background:#f1f1f1;\r\n                font-size:11px;\r\n                font-weight:bold;\r\n                padding:8px;\r\n                border:1px solid #7f8c69;\r\n            \">\r\n                Mob. No.\r\n            </td>\r\n\r\n            <td style=\"\r\n                background:#ffffff;\r\n                font-size:11px;\r\n                padding:8px;\r\n                border:1px solid #7f8c69;\r\n            \">\r\n                {{ doc.custom_mob_no or \"\" }}\r\n            </td>\r\n\r\n        </tr>\r\n\r\n    </table>\r\n\r\n</div>\r\n<!-- ================= CANDIDATE DETAILS ================= -->\r\n\r\n<div style=\"\r\n    background:#4d641c;\r\n    color:#ffffff;\r\n    font-weight:bold;\r\n    font-size:13px;\r\n    padding:5px 8px;\r\n    border:1px solid #7f8c69;\r\n    border-top:none;\r\n\">\r\n    A. Candidate Details\r\n</div>\r\n\r\n{% set ns = namespace(basic_salary = 0,food_allowance = 0,transportation_allowance = 0,other_allowance = 0) %}\r\n\r\n{% for row in doc.offer_terms %}\r\n\r\n    {% if row.offer_term==\"Basic Salary\"%}\r\n        {% set ns.basic_salary = row.value %}\r\n    {% endif %}\r\n\r\n    {% if row.offer_term==\"Food Allowance\"  %}\r\n        {% set ns.food_allowance = row.value %}\r\n    {% endif %}\r\n\r\n    {% if row.offer_term==\"Other Allowances\" %}\r\n        {% set ns.other_allowance = row.value %}\r\n    {% endif %}\r\n\r\n    {% if row.offer_term==\"Transport Allowances\" %}\r\n        {% set ns.transportation_allowance= row.value %}\r\n    {% endif %}\r\n\r\n{% endfor %}\r\n\r\n<table style=\"\r\n    width:100%;\r\n    border-collapse:collapse;\r\n    table-layout:fixed;\r\n    font-family:Arial, sans-serif;\r\n\">\r\n\r\n    <!-- ================= HEADER ================= -->\r\n\r\n    <tr>\r\n\r\n        <td colspan=\"3\" style=\"\r\n            text-align:center;\r\n            font-size:11px;\r\n            font-weight:bold;\r\n            color:#666;\r\n            background:#eef1e3;\r\n            border:1px solid #7f8c69;\r\n            padding:6px;\r\n        \">\r\n            Personal Data\r\n        </td>\r\n\r\n        <td colspan=\"3\" style=\"\r\n            text-align:center;\r\n            font-size:11px;\r\n            font-weight:bold;\r\n            color:#666;\r\n            background:#eef1e3;\r\n            border:1px solid #7f8c69;\r\n            padding:6px;\r\n        \">\r\n            Salary Data\r\n        </td>\r\n\r\n    </tr>\r\n\r\n    <!-- ================= SUB HEADER ================= -->\r\n\r\n    <tr>\r\n\r\n        <td style=\"\r\n            width:34%;\r\n            background:#eef1e3;\r\n            border:1px solid #7f8c69;\r\n        \" colspan=\"3\"></td>\r\n\r\n        <td style=\"\r\n            width:20%;\r\n            text-align:center;\r\n            font-size:11px;\r\n            font-weight:bold;\r\n            color:#666;\r\n            background:#f7f7f7;\r\n            border:1px solid #7f8c69;\r\n            padding:6px;\r\n        \">\r\n            Particulars\r\n        </td>\r\n\r\n        <td style=\"\r\n            width:15%;\r\n            text-align:center;\r\n            font-size:11px;\r\n            font-weight:bold;\r\n            color:#666;\r\n            background:#f7f7f7;\r\n            border:1px solid #7f8c69;\r\n            padding:6px;\r\n        \">\r\n            Offer Salary\r\n        </td>\r\n\r\n        <td style=\"\r\n            width:15%;\r\n            text-align:center;\r\n            font-size:11px;\r\n            font-weight:bold;\r\n            color:#666;\r\n            background:#f7f7f7;\r\n            border:1px solid #7f8c69;\r\n            padding:6px;\r\n        \">\r\n            Contract Salary\r\n        </td>\r\n\r\n    </tr>\r\n\r\n    <!-- ================= ROW 1 ================= -->\r\n\r\n    <tr>\r\n\r\n        <td style=\"\r\n            width:20%;\r\n            background:#f7f7f7;\r\n            font-size:11px;\r\n            \r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            Nationality\r\n        </td>\r\n\r\n        <td colspan=\"2\" style=\"\r\n            width:34%;\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            {{ doc.custom_applicant_nationality or \"\" }}\r\n        </td>\r\n\r\n        <td style=\"\r\n            width:20%;\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            Basic Salary\r\n        </td>\r\n\r\n        <td style=\"\r\n            width:15%;\r\n            text-align:center;\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            {{ ns.basic_salary }}\r\n        </td>\r\n\r\n        <td style=\"\r\n            width:15%;\r\n            text-align:center;\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            \r\n        </td>\r\n\r\n    </tr>\r\n\r\n    <!-- ================= ROW 2 ================= -->\r\n\r\n    <tr>\r\n\r\n        <td style=\"\r\n            background:#f7f7f7;\r\n            font-size:11px;\r\n            \r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            Age &amp; Date of Birth\r\n        </td>\r\n\r\n        <td style=\"\r\n            width:17%;\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n            text-align:center;\r\n        \">\r\n            {{ doc.custom_age or \"\" }}\r\n        </td>\r\n\r\n        <td style=\"\r\n            width:17%;\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n            text-align:center;\r\n        \">\r\n            {{ frappe.utils.formatdate(doc.custom_dob) if doc.custom_dob else \"\" }}\r\n        </td>\r\n\r\n        <td style=\"\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            Food Allow.\r\n        </td>\r\n\r\n        <td style=\"\r\n            text-align:center;\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            {{ ns.food_allowance }}\r\n        </td>\r\n\r\n        <td style=\"\r\n            border:1px solid #7f8c69;\r\n        \"></td>\r\n\r\n    </tr>\r\n\r\n    <!-- ================= ROW 3 ================= -->\r\n\r\n    <tr>\r\n\r\n        <td style=\"\r\n            background:#f7f7f7;\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            Visa Status\r\n        </td>\r\n\r\n        <td colspan=\"2\" style=\"\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            {{ doc.custom_visa_status or \"\" }}\r\n        </td>\r\n\r\n        <td style=\"\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            Transportation Allow.\r\n        </td>\r\n\r\n        <td style=\"\r\n            text-align:center;\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            {{ ns.transportation_allowance }}\r\n        </td>\r\n\r\n        <td style=\"\r\n            border:1px solid #7f8c69;\r\n        \"></td>\r\n\r\n    </tr>\r\n\r\n    <!-- ================= ROW 4 ================= -->\r\n\r\n    <tr>\r\n\r\n        <td style=\"\r\n            background:#f7f7f7;\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            Visa Expiry\r\n        </td>\r\n\r\n        <td colspan=\"2\" style=\"\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            {{ frappe.utils.formatdate(doc.custom_visa_expiry) if doc.custom_visa_expiry else \"\" }}\r\n        </td>\r\n\r\n        <td style=\"\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            Other Allowance\r\n        </td>\r\n\r\n        <td style=\"\r\n            text-align:center;\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            {{ ns.other_allowance }}\r\n        </td>\r\n\r\n        <td style=\"\r\n            border:1px solid #7f8c69;\r\n        \"></td>\r\n\r\n    </tr>\r\n\r\n    <!-- ================= ROW 5 ================= -->\r\n\r\n    <tr>\r\n\r\n        <td style=\"\r\n            background:#f7f7f7;\r\n            font-size:11px;\r\n            \r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            Availability\r\n        </td>\r\n\r\n        <td colspan=\"2\" style=\"\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            {{ doc.custom_availability or \"\" }}\r\n        </td>\r\n\r\n        <td style=\"\r\n            font-size:11px;\r\n            font-weight:bold;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            Total Salary\r\n        </td>\r\n\r\n        <td style=\"\r\n            text-align:center;\r\n            font-size:11px;\r\n            font-weight:bold;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            {{ (basic_salary or 0) + (food_allowance or 0) + (transportation_allowance or 0) + (other_allowance or 0) }}\r\n        </td>\r\n\r\n        <td style=\"\r\n            text-align:center;\r\n            font-size:11px;\r\n            font-weight:bold;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            \r\n        </td>\r\n\r\n    </tr>\r\n\r\n    <!-- ================= ROW 6 ================= -->\r\n\r\n    <tr>\r\n\r\n        <td style=\"\r\n            background:#f7f7f7;\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            Passport No.\r\n        </td>\r\n\r\n        <td colspan=\"2\" style=\"\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            {{ doc.custom_passport_no or \"\" }}\r\n        </td>\r\n\r\n        <td style=\"\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            Annual Air Ticket\r\n        </td>\r\n\r\n        <td style=\"\r\n            text-align:center;\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            {{ doc.custom_air_ticket_entitlement_cash_amount or 0 }}\r\n        </td>\r\n\r\n        <td style=\"\r\n            border:1px solid #7f8c69;\r\n        \"></td>\r\n\r\n    </tr>\r\n\r\n    <!-- ================= ROW 7 ================= -->\r\n\r\n    <tr>\r\n\r\n        <td style=\"\r\n            background:#f7f7f7;\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            Passport Exp.\r\n        </td>\r\n\r\n        <td colspan=\"2\" style=\"\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            {{ frappe.utils.formatdate(doc.custom_passport_exp) if doc.custom_passport_exp else \"\" }}\r\n        </td>\r\n\r\n        <td style=\"\r\n            font-size:11px;\r\n            font-style:italic;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            Remarks, if any:\r\n        </td>\r\n\r\n        <td colspan=\"2\" style=\"\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            {{ doc.custom_remarks or \"\" }}\r\n        </td>\r\n\r\n    </tr>\r\n\r\n    <!-- ================= ROW 8 ================= -->\r\n\r\n    <tr>\r\n\r\n        <td style=\"\r\n            background:#f7f7f7;\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            Years of Experience\r\n        </td>\r\n\r\n        <td colspan=\"2\" style=\"\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            {{ doc.custom_years_of_experience or \"\" }}\r\n        </td>\r\n\r\n        <td colspan=\"3\" rowspan=\"3\" style=\"\r\n            border:1px solid #7f8c69;\r\n            height:55px;\r\n        \"></td>\r\n\r\n    </tr>\r\n\r\n    <!-- ================= ROW 9 ================= -->\r\n\r\n    <tr>\r\n\r\n        <td style=\"\r\n            background:#f7f7f7;\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            Driving License Exp.\r\n        </td>\r\n\r\n        <td colspan=\"2\" style=\"\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            {{ frappe.utils.formatdate(doc.custom_driving_license_exp) if doc.custom_driving_license_exp else \"\" }}\r\n        </td>\r\n\r\n    </tr>\r\n\r\n    <!-- ================= ROW 10 ================= -->\r\n\r\n    <tr>\r\n\r\n        <td style=\"\r\n            background:#f7f7f7;\r\n            font-size:11px;\r\n            padding:7px;\r\n            border:1px solid #7f8c69;\r\n        \">\r\n            License Category\r\n        </td>\r\n\r\n        <td colspan=\"2\" style=\"\