 "html": "<style>\r\n\r\n@media screen {\r\n    .print-format {\r\n        width: 9.4in;\r\n        padding: 0.1in;\r\n        min-height: 11.7in;\r\n    }\r\n}\r\n\r\nbody {\r\n    margin: 0 !important;\r\n    padding: 0 !important;\r\n    font-family: Arial, sans-serif;\r\n}\r\n\r\ntable {\r\n    width: 100%;\r\n    border-collapse: collapse;\r\n    table-layout: fixed;\r\n}\r\n\r\ntd, th {\r\n    border: 1px solid #000;\r\n    padding: 5px;\r\n    font-size: 12px;\r\n    vertical-align: top;\r\n}\r\n\r\n.center { text-align: center; }\r\n.bold { font-weight: bold; }\r\n\r\n.grey { background: #e6e6e6; }\r\n\r\n.title {\r\n    font-size: 22px;\r\n    font-weight: bold;\r\n    text-align: center;\r\n}\r\n\r\n.sub-title {\r\n    text-align: center;\r\n    font-weight: bold;\r\n    color: #c00000;\r\n}\r\n\r\n.no-border {\r\n    border: none !important;\r\n}\r\n\r\n</style>\r\n\r\n{% set logo = frappe.db.get_single_value(\"Orion Settings\", \"company_logo\") %}\r\n\r\n<!-- ================= HEADER ================= -->\r\n<table>\r\n    <tr>\r\n        <td style=\"width:25%;\" class=\"no-border\">\r\n            {% if logo %}\r\n                <img src=\"{{ logo }}\" style=\"height:60px;\">\r\n            {% endif %}\r\n        </td>\r\n\r\n        <td class=\"title no-border\" style=\"width:50%;\">\r\n            HAND OVER FORM\r\n        </td>\r\n\r\n        <td style=\"width:25%;\" class=\"no-border\"></td>\r\n    </tr>\r\n</table>\r\n\r\n<table>\r\n    <tr>\r\n        <td class=\"sub-title no-border\">\r\n            ORION INTERNATIONAL FACILITY MANAGEMENT LLC\r\n        </td>\r\n    </tr>\r\n</table>\r\n\r\n<!-- ================= EMPLOYEE DETAILS ================= -->\r\n<table>\r\n\r\n    <tr>\r\n        <td class=\"bold\">Name of Employee</td>\r\n        <td >{{ doc.employee_name or \"\" }}</td>\r\n\r\n        <td class=\"bold\">Asset Transfer No</td>\r\n        <td>{{ doc.name }}</td>\r\n    </tr>\r\n\r\n    <tr>\r\n        <td class=\"bold\">Employee No</td>\r\n        <td >{{ doc.employee or \"\" }}</td>\r\n\r\n        <td class=\"bold\">Department</td>\r\n        <td>{{ doc.department or \"\" }}</td>\r\n    </tr>\r\n\r\n    <tr>\r\n        <td class=\"bold\">Designation</td>\r\n        <td>{{ doc.designation or \"\" }}</td>\r\n\r\n        <td class=\"bold\">Handover By</td>\r\n        <td>\r\n            {% if doc.asset_handover_detail and doc.asset_handover_detail[0].issued_by %}\r\n                {{ doc.asset_handover_detail[0].issued_by }}\r\n            {% endif %}\r\n        </td>\r\n    </tr>\r\n\r\n</table>\r\n\r\n<!-- ================= LETTER ================= -->\r\n<table>\r\n    <tr>\r\n        <td class=\"no-border\" style=\"padding-top:10px;\">\r\n            Dear Sir,\r\n            <br><br>\r\n\r\n            Please find the details below as the company assets handed over to me,\r\n            to support me in carrying out my task in the most proficient manner.\r\n        </td>\r\n    </tr>\r\n</table>\r\n\r\n<!-- ================= ASSET TABLE ================= -->\r\n<table>\r\n\r\n    <tr class=\"grey bold center\">\r\n        <td style=\"width:5%;\">SN</td>\r\n        <td style=\"width:20%;\">DESCRIPTION</td>\r\n        <td style=\"width:15%;\">ASSET CODE</td>\r\n        <td style=\"width:8%;\">QTY</td>\r\n        <td style=\"width:12%;\">HANDOVER DATE</td>\r\n        <td style=\"width:12%;\">HANDOVER BY</td>\r\n        <td style=\"width:10%;\">STATUS</td>\r\n        <td style=\"width:18%;\">REMARKS</td>\r\n    </tr>\r\n\r\n    {% for row in doc.asset_handover_detail %}\r\n\r\n    <tr>\r\n        <td class=\"center\">{{ loop.index }}</td>\r\n\r\n        <td>\r\n            {{ row.asset_type or row.device_type or \"\" }}\r\n        </td>\r\n\r\n        <td >\r\n            {{ row.asset_code or \"\" }}\r\n        </td>\r\n\r\n        <td class=\"center\">\r\n            {{ row.qty or 0 }}\r\n        </td>\r\n\r\n        <td class=\"center\">\r\n            {% if row.issued_date %}\r\n                {{ frappe.utils.formatdate(row.issued_date, \"dd/MM/yyyy\") }}\r\n            {% endif %}\r\n        </td>\r\n\r\n        <td >\r\n            {{ row.issued_by or \"\" }}\r\n        </td>\r\n\r\n        <td class=\"center\">\r\n            {{ row.asset_status or \"\" }}\r\n        </td>\r\n\r\n        <td>\r\n            {{row.remarks}}\r\n        </td>\r\n    </tr>\r\n\r\n    {% endfor %}\r\n\r\n    <tr>\r\n        <td></td>\r\n        <td class=\"bold\">Overall Remarks</td>\r\n        <td colspan=\"6\">\r\n            {{ doc.remarks or \"Issued with charger\" }}\r\n        </td>\r\n    </tr>\r\n\r\n</table>\r\n\r\n<!-- ================= SIGNATURES ================= -->\r\n<table>\r\n\r\n    <tr class=\"center bold\">\r\n        <td>Received By</td>\r\n        <td>Acknowledged By</td>\r\n        <td>Approved By</td>\r\n    </tr>\r\n\r\n    <tr style=\"height:70px;\">\r\n        <td></td>\r\n        <td></td>\r\n        <td></td>\r\n    </tr>\r\n\r\n    <tr class=\"center\">\r\n        <td>{{ doc.employee_name or \"\" }}</td>\r\n        <td></td>\r\n        <td>Management</td>\r\n    </tr>\r\n\r\n</table>\r\n\r\n<!-- ================= DECLARATION ================= -->\r\n<table>\r\n\r\n    <tr>\r\n        <td>\r\n\r\n            <b>ACKNOWLEDGEMENT AND DECLARATION BY EMPLOYEE</b>\r\n\r\n            <br><br>\r\n\r\n            I, {{ doc.employee_name or \"\" }}, hereby acknowledge that I have received the above mentioned assets. I understand that these assets belong to <b>ORION INTERNATIONAL FACILITY MANAGEMENT LLC</b> and are under my possession for carrying out official duties.\r\n\r\n            <br><br>\r\n\r\n            I hereby assure that I will take care of the company assets to the best possible extent. Any damage or loss of the assets due to negligence will be borne by me. If I commit any misconduct towards this declaration, I will be liable for disciplinary action including termination of my employment.\r\n\r\n            <br><br><br><br>\r\n\r\n            <div style=\"text-align:right; font-weight:bold; padding-right:40px;\">\r\n    _________________________\r\n    <br>\r\n    EMPLOYEE SIGNATURE\r\n</div>\r\n\r\n        </td>\r\n    </tr>\r\n\r\n</table>\r\n\r\n<!-- ================= OTHER REMARKS ================= -->\r\n<table>\r\n\r\n    <tr>\r\n        <td class=\"bold\">OTHER REMARKS:</td>\r\n    </tr>\r\n\r\n    <tr style=\"height:60px;\">\r\n        <td></td>\r\n    </tr>\r\n\r\n</table>",
