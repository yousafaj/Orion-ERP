 "doctype": "Print Format",
 "font_size": 14,
 "html": "<style>\r\n\r\n@media screen {\r\n    .print-format {\r\n        width: 9.4in;\r\n        padding: 0.15in;\r\n        min-height: 11.7in;\r\n        font-size: 12px;\r\n    }\r\n}\r\n\r\nbody { margin:0; padding:0; }\r\n\r\ntable {\r\n    width:100%;\r\n    border-collapse:collapse;\r\n    table-layout:fixed;\r\n}\r\n\r\ntd {\r\n    border:1px solid #000;\r\n    padding:6px 8px;\r\n    vertical-align:middle;\r\n}\r\n\r\n.center { text-align:center; }\r\n.bold { font-weight:700; }\r\n\r\n.green { background:#556b2f; color:#fff; font-weight:700; }\r\n.grey { background:#c4c7b5; font-weight:600; }\r\n.yellow { background:#ffff00; }\r\n\r\n</style>\r\n\r\n{% set logo = frappe.db.get_single_value(\"Orion Settings\", \"company_logo\") %}\r\n\r\n<!-- ================= HEADER ================= -->\r\n{% set logo = frappe.db.get_single_value(\"Orion Settings\", \"company_logo\") %}\r\n\r\n<!-- ===== TOP ROW (LOGO + DOC REF) ===== -->\r\n<table style=\"border:2px solid #000; border-bottom:0;text-align: right;\">\r\n<tr>\r\n\r\n    <!-- LOGO -->\r\n   <td style=\"width:30%; border-right:0;\">\r\n        {% if logo %}\r\n        <img src=\"{{ logo }}\" style=\"height:55px;\">\r\n        {% endif %}\r\n    </td>\r\n\r\n    <!-- DOC REF -->\r\n    <td class=\"right\" style=\"width:50%; border-left:0; font-size:13px;\">\r\n        Doc Ref : {{doc.name}}\r\n    </td>\r\n\r\n</tr>\r\n</table>\r\n\r\n<!-- ===== TITLE ROW (FULL GREEN BAR) ===== -->\r\n<table style=\"border:2px solid #000; border-top:0;\">\r\n<tr>\r\n    <td class=\"center bold\" style=\"\r\n        background:#c4d1a3;\r\n        font-size:20px;\r\n        padding:10px 0;\r\n        letter-spacing:1px;\r\n    \">\r\n        DUTY RESUMPTION FORM\r\n    </td>\r\n</tr>\r\n</table>\r\n<!-- ================= BASIC ================= -->\r\n<table style=\"border:2px solid #000; border-top:0;\">\r\n<tr>\r\n    <td class=\"grey\">Name of Employee :</td>\r\n    <td class=\"yellow\">{{ doc.employee_name }}</td>\r\n    <td class=\"grey\">Staff ID No. :</td>\r\n    <td class=\"yellow\">{{ doc.employee }}</td>\r\n</tr>\r\n\r\n<tr>\r\n    <td class=\"grey\">Designation :</td>\r\n    <td class=\"yellow\">{{ doc.designation }}</td>\r\n    <td class=\"grey\">Department :</td>\r\n    <td class=\"yellow\">{{ doc.department }}</td>\r\n</tr>\r\n</table>\r\n\r\n<!-- ================= RESUMPTION ================= -->\r\n<table style=\"border:2px solid #000; border-top:0;\">\r\n<tr>\r\n    <td colspan=\"6\" class=\"green\">Resumption Details</td>\r\n</tr>\r\n\r\n<tr>\r\n    <td class=\"grey\">Reporting Date :</td>\r\n    <td class=\"yellow\">{{ frappe.utils.formatdate(doc.reporting_date,\"dd/MM/yyyy\") }}</td>\r\n    <td class=\"grey\">Reporting Time :</td>\r\n    <td class=\"yellow\">{{ doc.reporting_time }}</td>\r\n    <td class=\"grey\">Reporting Location :</td>\r\n    <td class=\"yellow\">{{ doc.reporting_location }}</td>\r\n</tr>\r\n</table>\r\n\r\n<!-- ================= DECLARATION ================= -->\r\n<table style=\"border:2px solid #000; border-top:0;\">\r\n<tr>\r\n    <td colspan=\"2\" class=\"green\">Declaration</td>\r\n</tr>\r\n\r\n<tr>\r\n    <!-- LEFT: ASSETS -->\r\n    <td style=\"height:80px; vertical-align:top;\">\r\n\r\n        {% for row in doc.assets %}\r\n            <div style=\"margin-bottom:4px;\">\r\n                <input type=\"checkbox\" checked> {{ row.assets or \"\" }}\r\n            </div>\r\n        {% endfor %}\r\n\r\n    </td>\r\n\r\n    <!-- RIGHT: OTHER -->\r\n    <td style=\"vertical-align:top;\">\r\n\r\n        <div style=\"display:flex; align-items:center; gap:8px;\">\r\n            <input type=\"checkbox\" {% if doc.other %}checked{% endif %}>\r\n            <b>Other :</b>\r\n            <span>{{ doc.other_declaration or \"\" }}</span>\r\n        </div>\r\n\r\n    </td>\r\n</tr>\r\n</table>\r\n\r\n<!-- ================= SIGNATURE ================= -->\r\n<table style=\"border:2px solid #000; border-top:0;\">\r\n<tr>\r\n    <td class=\"green center\">Employee Signature</td>\r\n    <td class=\"green center\">Reporting Officer Signature</td>\r\n</tr>\r\n\r\n<tr>\r\n    <td style=\"height:100px;\">\r\n        Sign : <br><br>\r\n        <i>Remarks, if any:</i>\r\n    </td>\r\n\r\n    <td>\r\n        Sign : <br><br>\r\n        <i>Remarks, if any:</i>\r\n    </td>\r\n</tr>\r\n</table>\r\n\r\n<!-- ================= OFFICE ================= -->\r\n<table style=\"border:2px solid #000; border-top:0;\">\r\n\r\n<tr>\r\n    <td colspan=\"2\" class=\"center bold\" style=\"background:#000;color:#fff;\">\r\n        FOR OFFICE USE ONLY\r\n    </td>\r\n</tr>\r\n\r\n<tr>\r\n    <td colspan=\"2\" class=\"green\">TO BE FILLED BY DEPARTMENT IN-CHARGE</td>\r\n</tr>\r\n\r\n<tr>\r\n\r\n    <!-- LEFT SIDE -->\r\n    <td style=\"width:50%; padding:0;\">\r\n\r\n        <table style=\"width:100%; border:none;\">\r\n\r\n            <tr>\r\n                <td class=\"grey\" style=\"width:50%;\">Approved<br>Rejoining Date</td>\r\n               \r\n                <td class=\"yellow\">\r\n                    {{ frappe.utils.formatdate(doc.approved_rejoining_date,\"dd/MM/yyyy\") }}\r\n                </td>\r\n            </tr>\r\n\r\n            <tr>\r\n                <td class=\"grey\">Site Allocated</td>\r\n              \r\n                <td class=\"yellow\">{{ doc.site_allocated }}</td>\r\n            </tr>\r\n\r\n            <tr>\r\n                <td class=\"grey\">Mobilization Date</td>\r\n             \r\n                <td class=\"yellow\">\r\n                    {{ frappe.utils.formatdate(doc.mobilization__date,\"dd/MM/yyyy\") }}\r\n                </td>\r\n            </tr>\r\n\r\n        </table>\r\n\r\n    </td>\r\n\r\n    <!-- RIGHT SIDE -->\r\n    <td style=\"width:50%; padding:0; vertical-align:top;\">\r\n\r\n        <table style=\"width:100%; height:100%; border:none;\">\r\n\r\n            <tr>\r\n                <td style=\"height:90px; vertical-align:top; border-bottom:1px solid #000;\">\r\n                    <i>Remarks, if any:</i>\r\n                </td>\r\n            </tr>\r\n\r\n            <tr>\r\n                <td style=\"padding:10px;\">\r\n                    Name: {{ doc.department_in_charge_name }}<br><br>\r\n                    Date: {{ frappe.utils.formatdate(doc.date_incharge,\"dd/MM/yyyy\") }}<br><br>\r\n                    Signature:\r\n                </td>\r\n            </tr>\r\n\r\n        </table>\r\n\r\n    </td>\r\n\r\n</tr>\r\n\r\n</table>\r\n<!-- ================= HR SECTION ================= -->\r\n<!-- ================= HR SECTION ================= -->\r\n<table style=\"border:2px solid #000; border-top:0;\">\r\n\r\n<tr>\r\n    <td colspan=\"2\" class=\"green\">TO BE FILLED BY HR DEPARTMENT</td>\r\n</tr>\r\n\r\n<tr>\r\n\r\n    <!-- LEFT BOX (same as department) -->\r\n    <td style=\"width:50%; padding:10px; vertical-align:top;\">\r\n\r\n        <table style=\"width:90%; border-collapse:collapse; margin-left:10px;\">\r\n\r\n            <tr>\r\n                <td class=\"grey\" style=\"width:55%;\">Leave Start date</td>\r\n                <td class=\"yellow\">\r\n                    {{ frappe.utils.formatdate(doc.leave_start_date,\"dd/MM/yyyy\") }}\r\n                </td>\r\n            </tr>\r\n\r\n            <tr>\r\n                <td class=\"grey\">Leave end date</td>\r\n                <td class=\"yellow\">\r\n                    {{ frappe.utils.formatdate(doc.leave_end_date,\"dd/MM/yyyy\") }}\r\n                </td>\r\n            </tr>\r\n\r\n            <tr>\r\n                <td class=\"grey\">Leave Type</td>\r\n                <td class=\"yellow\">{{ doc.leave_type }}</td>\r\n            </tr>\r\n\r\n            <tr>\r\n                <td class=\"grey\">Leave Days Approved</td>\r\n                <td class=\"yellow\">{{ doc.leave_days_approved }}</td>\r\n            </tr>\r\n\r\n            <tr>\r\n                <td class=\"grey\">Tentative Rejoining Date</td>\r\n                <td class=\"yellow\">\r\n                    {{ frappe.utils.formatdate(doc.tentative_rejoining_date,\"dd/MM/yyyy\") }}\r\n                </td>\r\n            </tr>\r\n\r\n            <tr>\r\n                <td class=\"grey\">Actual Rejoining Date</td>\r\n                <td class=\"yellow\">\r\n                    {{ frappe.utils.formatdate(doc.actual_rejoining_date,\"dd/MM/yyyy\") }}\r\n                </td>\r\n            </tr>\r\n\r\n        </table>\r\n\r\n    </td>\r\n\r\n    <!-- RIGHT BOX (same as department) -->\r\n    <td style=\"width:50%; padding:10px; vertical-align:top;\">\r\n\r\n        <table style=\"width:95%; border-collapse:collapse;\">\r\n\r\n            <tr>\r\n                <td style=\"height:120px; vertical-align:top; border:1px solid #000;\">\r\n                    <i>Remarks, if any:</i>\r\n                </td>\r\n            </tr>\r\n\r\n            <tr>\r\n                <td style=\"padding:10px; border:1px solid #000;\">\r\n                    Name: {{ doc.hr_id }}<br><br>\r\n                    Date:{{frappe.utils.formatdate(doc.date_hr,\"dd/MM/yyyy\") }}<br><br>\r\n                    Signature:\r\n                </td>\r\n            </tr>\r\n\r\n        </table>\r\n\r\n    </td>\r\n\r\n</tr>\r\n\r\n</table>\r\n\r\n<!-- ================= MANAGEMENT APPROVAL ================= -->\r\n<table style=\"border:2px solid #000; border-top:0;\">\r\n\r\n<tr>\r\n    <td colspan=\"2\" class=\"green\">MANAGEMENT APPROVAL</td>\r\n</tr>\r\n\r\n<tr>\r\n\r\n    <!-- LEFT SIDE -->\r\n    <td style=\"width:50%; height:140px; vertical-align:top; padding:10px;\">\r\n        Date:<br><br>\r\n        <i>Remarks, if any:</i>\r\n    </td>\r\n\r\n    <!-- RIGHT SIDE -->\r\n    <td style=\"width:50%; vertical-align:top; padding:10px;\">\r\n        Date:<br><br>\r\n        <i>Remarks, if any:</i>\r\n    </td>\r\n\r\n</tr>\r\n\r\n</table>",
